[[0mparagraph[0m] TEXT [108.0, 695.6, 523.7, 713.0]: 'สูตรทางคณิตศาสตร์ที่ใช้แสดงความสัมพันธ์ระหว่างตัวแปรตั้งแต่ 2 ตัวขึ้นไป เพื่อ'
[[0mparagraph[0m] TEXT [108.0, 718.1, 523.3, 735.6]: 'ท านายหาค่าตัวแปรตาม (Y) จากค่าตัวแปรอิสระ (X) โดยมีรูปแบบพื้นฐานคือ Y = a + bX + ε (ส าหรับ'
[[0mparagraph[0m] TEXT [108.0, 739.4, 522.7, 756.8]: 'เชิงเส้นอย่างง่าย) ซึ่งหมายถึง ค่าที่คาดหวัง (Y) เท่ากับ จุดตัดแกน (a) บวกความชัน (b) คูณกับตัว'

================== PAGE 9 ==================
[[0mparagraph[0m] TEXT [108.0, 109.8, 522.9, 127.3]: 'แปรอิสระ (X) บวกด้วยค่าความคลาดเคลื่อน (ε) สมการนี้ช่วยให้เข้าใจว่า ตัวแปรหนึ่งมีผลกับ'
[[0mparagraph[0m] TEXT [108.0, 131.0, 457.9, 148.5]: 'อีกตัวแปรหนึ่งอย่างไรและสามารถน ามาคาดการณ์แนวโน้มเกิดขึ้น ในอนาคตได้'
[[0mparagraph[0m] TEXT [108.0, 152.3, 264.9, 169.7]: 'สมการถดถอยอย่างง่าย'
[[0mparagraph[0m] TEXT [292.7, 194.9, 526.5, 212.3]: 'Y = a + bX + e                                        (2.2)'
[[0mparagraph[0m] TEXT [108.0, 216.2, 354.8, 233.7]: 'เมื่อ Y คือ ตัวแปรตาม'
[[0mparagraph[0m] TEXT [108.0, 237.5, 336.6, 254.9]: 'a คือ ค่าคงที่'
[[0mparagraph[0m] TEXT [108.0, 258.9, 414.3, 276.3]: 'b คือ ค่าสัมประสิทธ์การถดถอย'
[[0mparagraph[0m] TEXT [108.0, 280.1, 350.1, 297.6]: 'X คือ ตัวแปรต้น'
[[0mparagraph[0m] TEXT [108.0, 301.5, 394.1, 318.9]: 'e คือ ค่าความคลาดเคลื่อน'
[[0mparagraph[0m] TEXT [108.0, 344.1, 256.6, 361.5]: 'สมการถดถอยพหุคูณ'
[[0mparagraph[0m] TEXT [216.1, 386.5, 525.1, 404.7]: 'Y = a + b1X1 + b2X2 + b3X3 + b4X4 + b5X5 + e                    (2.3)'
[[0mparagraph[0m] TEXT [108.0, 407.9, 398.4, 425.4]: 'เมื่อ Y คือ ความพึงพอใจโดยรวม'
[[0mparagraph[0m] TEXT [108.0, 429.2, 325.7, 447.3]: 'X1 คือ ด้านกายภาพ'
[[0mparagraph[0m] TEXT [108.0, 450.5, 329.1, 468.7]: 'X2 คือ ด้านน่าเชื่อถือ'
[[0mparagraph[0m] TEXT [108.0, 471.8, 384.9, 489.9]: 'X3 คือ ด้านการตอบสนอง'
[[0mparagraph[0m] TEXT [108.0, 493.1, 404.3, 511.3]: 'X4 คือ ด้านการให้ความเชื่อมั่น'
[[0mparagraph[0m] TEXT [108.0, 514.4, 376.1, 532.5]: 'X5 คือ ด้านการเอาใจใส่'
[[0mparagraph[0m] TEXT [108.0, 557.0, 524.1, 575.1]: 'b1 ถึง b5 ค่าอิทธิพลของแต่ละมิติ (ถ้าbตัวไหนสูงแสดงว่ามิตินั้นส่งผลต่อความพึงพอใจ)'
[[96msub_section[0m] PREFIX [136.3, 578.3, 158.9, 595.8]: '[96m2.2.4[0m' | TEXT [164.7, 578.3, 213.6, 595.8]: 'สมการ IOC'
[[0mparagraph[0m] TEXT [108.0, 599.6, 522.2, 617.0]: 'คือ ค่าดัชนีที่ใช้ตรวจสอบความสอดคล้องของข้อค าถามกับวัตถุประสงค์ของงานวิจัย'
[[0mparagraph[0m] TEXT [108.0, 620.9, 338.3, 638.4]: 'หรือเนื้อหาที่ต้องใช้ โดยให้ผู้เชี่ยวชาญประเมินแต่ละข้อ'
[[0mparagraph[0m] TEXT [108.0, 642.2, 523.5, 659.6]: 'มักใช้ในงานวิจัยประเภท แบบสอบถาม แบบทดสอบ หรือเครื่องมือที่ใช้ในการวัด'
[[0mparagraph[0m] TEXT [108.0, 663.5, 204.4, 681.0]: 'ต่างๆ ก่อนน าไปใช้จริง'

