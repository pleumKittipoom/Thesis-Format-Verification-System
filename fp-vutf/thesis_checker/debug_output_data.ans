
================== PAGE 1 ==================
[[92mchapter[0m] PREFIX [300.3, 108.5, 331.0, 125.9]: '[92mบทที่ 1[0m' | TEXT None: ''
[[0mparagraph[0m] TEXT [302.5, 129.7, 332.5, 147.2]: 'บทน ำ'
[[94msection[0m] PREFIX [108.0, 172.3, 122.8, 189.8]: '[94m1.1[0m' | TEXT [136.3, 172.3, 281.2, 189.8]: 'ที่มำและควำมส ำคัญของโครงงำน'
[[0mparagraph[0m] TEXT [108.0, 193.7, 523.4, 211.1]: 'หลักสูตรวิศวกรรมศาสตรบัณฑิตได้มุ่งเน้นที่จะผลิตนักศึกษาให้มีประสิทธิภาพที่สูง ทั้งในทาง'
[[0mparagraph[0m] TEXT [108.0, 214.9, 522.5, 232.4]: 'ทฤษฎีและในทางปฏิบัติ เพื่อรองรับพลวัตของความต้องการในภาคของอุตสาหกรรม ดังนั้น การ'
[[0mparagraph[0m] TEXT [108.0, 236.3, 522.3, 253.7]: 'ยกระดับประสิทธิภาพในการเรียนรู้ จึงเป็นหน้าที่ส าคัญของสถาบันการศึกษา โดยมีความพอใจของ'
[[0mparagraph[0m] TEXT [108.0, 257.5, 526.7, 275.0]: 'นักศึกษา เป็นดัชนีชี้วัดที่ใช้ในการวัดคุณภาพที่สะท้อนมุมมองในด้านต่างๆของผู้ที่มารับบริการ'
[[0mparagraph[0m] TEXT [108.0, 278.9, 523.3, 296.4]: 'ครอบคลุมทั้งด้านเนื้อหาวิชาการ กระบวนการที่ใช้ในการให้ความรู้ และสิ่งที่จะท าให้เกิดความสะดวก'
[[0mparagraph[0m] TEXT [108.0, 300.1, 522.6, 317.6]: 'สะบาย มีกระบวนการจัดท าการประเมินผลอย่างเป็นระบบจะช่วยระบุช่องว่างเพื่อการพัฒนาและ'
[[0mparagraph[0m] TEXT [108.0, 321.5, 288.7, 339.0]: 'เพิ่มประสิทธิผลทางการศึกษาได้อย่างสูงสุด'
[[0mparagraph[0m] TEXT [108.0, 342.7, 522.9, 360.2]: 'การประยุกต์ใช้เกณฑ์คุณภาพ SERVQUAL ในบริบททางการศึกษา มุ่งเน้นการเปรียบเทียบ'
[[0mparagraph[0m] TEXT [108.0, 364.1, 523.0, 381.6]: 'ความคาดหวังในด้านการบริการกับสิ่งที่นักศึกษารับรู้จริงโดยมีอยู่ 5 มิติส าคัญ ตั้งแต่ด้านกายภาพไป'
[[0mparagraph[0m] TEXT [108.0, 385.3, 523.0, 402.8]: 'จนถึงความเอาใจใส่ในรายบุคคลเพื่อให้ผลประเมินได้สะท้อนถึงคุณภาพในทางด้านการเรียนรู้'
[[0mparagraph[0m] TEXT [108.0, 406.7, 238.1, 424.2]: 'อย่างรอบด้านและเป็นรูปธรรม'
[[0mparagraph[0m] TEXT [108.0, 428.0, 523.3, 445.4]: 'ผู้ที่จัดท าวิจัยจึงได้มีการน า SERVQUAL มาปรับใช้ในการประเมิน ความพึงพอใจของ'
[[0mparagraph[0m] TEXT [108.0, 449.2, 523.3, 466.7]: 'นักเรียน นักศึกษาคณะวิศวกรรมศาสตร์ โดยผู้จัดท าได้มีการมุ่งหวังให้ผลการศึกษาของผู้ศึกษาพัฒนา'
[[0mparagraph[0m] TEXT [108.0, 470.6, 518.0, 488.0]: 'และได้มีการยกระดับคุณภาพ ให้สามารถที่จะตอบรับกับความคาดหวังในการเรียนรู้ของนักศึกษาได้'
[[94msection[0m] PREFIX [108.0, 513.2, 122.8, 530.6]: '[94m1.2[0m' | TEXT [136.3, 513.2, 246.8, 530.6]: 'วัตถุประสงค์ของโครงงำน'
[[96msub_section[0m] PREFIX [136.3, 534.4, 158.9, 551.9]: '[96m1.2.1[0m' | TEXT [164.7, 534.4, 523.5, 551.9]: 'เพื่อศึกษาระดับของความคาดหวังและระดับในการรับรู้ของผู้เรียนต่อคุณภาพในการ'
[[0mparagraph[0m] TEXT [108.0, 555.8, 270.6, 573.2]: 'เรียนการสอนตามแนวคิด SERVQUAL'
[[96msub_section[0m] PREFIX [136.3, 577.0, 158.9, 594.5]: '[96m1.2.2[0m' | TEXT [164.7, 577.0, 523.3, 594.5]: 'เพื่อประเมินระดับคุณภาพของบริการทางด้านการศึกษาของ คณะวิศวกรรมศาสตร์โดย'
[[0mparagraph[0m] TEXT [108.0, 598.4, 275.8, 615.8]: 'ได้มีการจ าแนกตามมิติของ SERVQUAL'
[[96msub_section[0m] PREFIX [136.3, 619.6, 158.9, 637.1]: '[96m1.2.3[0m' | TEXT [164.7, 619.6, 523.1, 637.1]: 'เพื่อวิเคราะห์ความสัมพันธ์ของปัจจัยในคุณภาพการบริการ 5 มิติ กับระดับความพึง'
[[0mparagraph[0m] TEXT [108.0, 641.0, 188.4, 658.4]: 'พอใจของนักศึกษา'
[[94msection[0m] PREFIX [108.0, 683.6, 122.8, 701.0]: '[94m1.3[0m' | TEXT [136.3, 683.6, 228.8, 701.0]: 'ขอบเขตของโครงงำน'
[[0mparagraph[0m] TEXT [108.0, 704.8, 522.9, 722.3]: 'การวิจัยนี้ได้ศึกษาการถ่ายทอดความรู้ในการจัดการเรีนกรสอน ที่มีอิทธิพลต่อระดับความ'
[[0mparagraph[0m] TEXT [108.0, 726.2, 526.8, 743.6]: 'พึงใจในกลุ่มผู้เรียน โดยได้มีการน าการประยุกต์ใช้แบบจ าลองคุณภาพในการบริการ (SEVQUAL'
[[0mparagraph[0m] TEXT [108.0, 747.4, 145.2, 764.9]: 'Model)'

================== PAGE 2 ==================
[[96msub_section[0m] PREFIX [136.3, 108.5, 158.9, 125.9]: '[96m1.3.1[0m' | TEXT [164.7, 108.5, 245.0, 125.9]: 'ขอบเขตด้านเนื้อหา'
[[0mparagraph[0m] TEXT [108.0, 129.7, 523.2, 147.2]: 'ได้มีการศึกษาเกณฑ์มาตรฐานที่ใช้ในการศึกษา เพื่อวัดระดับผลสัมฤทธิ์ ในการจัด'
[[0mparagraph[0m] TEXT [108.0, 151.1, 523.4, 168.5]: 'กิจกรรมการเรียนการสอน โดยผ่านมุมมองของนักศึกษา โดยประยุกต์ใช้แนวคิด 5 ด้านของ'
[[0mparagraph[0m] TEXT [108.0, 172.3, 523.4, 189.8]: 'แบบจ าลองคุณภาพในการให้บริการ ได้แก่ ด้านกายภาพ ด้านความน่าเชื่อถือ ด้านการตอบสนองต่อ'
[[0mparagraph[0m] TEXT [108.0, 193.7, 400.8, 211.1]: 'ความต้องการที่รวดเร็ว มีการสร้างความเชื่อมั่น และมีการดูแลเอาใจใส่'
[[96msub_section[0m] PREFIX [136.3, 214.9, 158.9, 232.4]: '[96m1.3.2[0m' | TEXT [164.7, 214.9, 257.2, 232.4]: 'ขอบเขตด้านประชากร'
[[0mparagraph[0m] TEXT [108.0, 236.3, 523.3, 253.7]: 'ประชากร คือ นักศึกษาที่ก าลังศึกษาอยู่ในระดับปริญญาตรี คณะวิศวกรรมศาสตร์ ในปี'
[[0mparagraph[0m] TEXT [108.0, 257.5, 476.0, 275.0]: 'ศึกษา 2568 โดยได้มีการด าเนินการเลือกกลุ่มตัวอย่าง ให้มีความสอดคล้องกับวิธีการวิจัย'
[[96msub_section[0m] PREFIX [136.3, 278.9, 158.9, 296.4]: '[96m1.3.3[0m' | TEXT [164.7, 278.9, 522.4, 296.4]: 'ขอบเขตด้านพื้นที่ คณะวิศวกรรมศาสตร์ ณ มหาวิทยาลัยเทคโนโลยีราชมงคลธัญบุรี'
[[96msub_section[0m] PREFIX [136.3, 300.1, 158.9, 317.6]: '[96m1.3.4[0m' | TEXT [164.7, 300.1, 241.3, 317.6]: 'ขอบเขตระยะเวลา'
[[0mparagraph[0m] TEXT [108.0, 321.5, 523.0, 339.0]: 'ในการด าเนินงานการวิจัย กรอบระยะเวลาที่ใช้ในการจัดท าและรวบรวมข้อมูล ได้'
[[0mparagraph[0m] TEXT [108.0, 342.7, 332.9, 360.2]: 'ครอบคลุมช่วง 1 ปีการศึกษา ตามแผนด าเนินการวิจัย'
[[94msection[0m] PREFIX [108.0, 385.3, 122.8, 402.8]: '[94m1.4[0m' | TEXT [136.3, 385.3, 249.1, 402.8]: 'ประโยชน์ที่คำดว่ำจะได้รับ'
[[96msub_section[0m] PREFIX [136.3, 406.7, 158.9, 424.2]: '[96m1.4.1[0m' | TEXT [164.7, 406.7, 522.0, 424.2]: 'สะท้อนภาพรวมของความรู้สึกนึกคิดและความคิดเห็นต่างๆของนักศึกษาที่มีต่อระบบ'
[[0mparagraph[0m] TEXT [108.0, 428.0, 216.4, 445.4]: 'การเรียนการสอนปัจจุบัน'
[[96msub_section[0m] PREFIX [136.3, 449.2, 158.9, 466.7]: '[96m1.4.2[0m' | TEXT [164.7, 449.2, 523.4, 466.7]: 'ชี้จุดเด่นที่ควรรักษาและช่องว่างต้องด าเนินการแก้ไขในทุกๆมิติของด้านการบริการ'
[[0mparagraph[0m] TEXT [108.0, 470.6, 186.3, 488.0]: 'เพื่อพัฒนาที่ถูกจุด'
[[96msub_section[0m] PREFIX [136.3, 491.8, 158.9, 509.3]: '[96m1.4.3[0m' | TEXT [164.7, 491.8, 522.4, 509.3]: 'ใช้เป็นฐานข้อมูลที่ส าคัญก าหนดทิศทางและนโยบายในการยกระดับ คณะ'
[[0mparagraph[0m] TEXT [108.0, 513.2, 180.1, 530.6]: 'วิศวกรรมศาสตร์'
[[96msub_section[0m] PREFIX [136.3, 534.4, 158.9, 551.9]: '[96m1.4.4[0m' | TEXT [164.7, 534.4, 523.2, 551.9]: 'ขับเคลื่อนและเพิ่มระดับมาตรฐานในการศึกษาให้ตอบโจทย์ต่อความพึงพอใจของ'
[[0mparagraph[0m] TEXT [108.0, 555.8, 148.7, 573.2]: 'นักศึกษา'

================== PAGE 3 ==================
[[92mchapter[0m] PREFIX [300.3, 108.5, 331.0, 125.9]: '[92mบทที่ 2[0m' | TEXT None: ''
[[0mparagraph[0m] TEXT [251.6, 129.7, 383.5, 147.2]: 'งานวิจัยและทฤษฎีที่เกี่ยวข้อง'
[[0mparagraph[0m] TEXT [108.0, 172.3, 522.8, 189.8]: 'งานวิจัยนี้ได้น าแนวคิดที่เกี่ยวข้องกับการวัดคุณภาพบริการ (SERVQUAL) ในการวิเคราะห์'
[[0mparagraph[0m] TEXT [108.0, 193.7, 521.7, 211.1]: 'ความพึงพอใจในการเรียนของคณะวิศวกรรมศาสตร์ โดยมีการน าแนวคิด ทฤษฎี และงานวิจัยทีมี'
[[0mparagraph[0m] TEXT [108.0, 214.9, 522.9, 232.4]: 'ความเกี่ยวข้องกับแนวคิดในการด าเนินการศึกษา โดยเครื่องมือส าคัญที่ใช้ประเมินคุณภาพในด้านการ'
[[0mparagraph[0m] TEXT [108.0, 236.3, 526.8, 253.7]: 'บริการโดยการวัดช่องว่าง (Gap) ระหว่าง ความคาดหวัง (Expectation) และ การรับรู้จริง'
[[0mparagraph[0m] TEXT [108.0, 257.5, 247.6, 275.0]: '(Perception) ของผู้มารับบริการ'
[[94msection[0m] PREFIX [108.0, 300.1, 122.8, 317.6]: '[94m2.1[0m' | TEXT [136.3, 300.1, 218.7, 317.6]: 'งานวิจัยที่เกี่ยวข้อง'
[[96msub_section[0m] PREFIX [136.3, 321.5, 158.9, 339.0]: '[96m2.1.1[0m' | TEXT [164.7, 321.5, 523.4, 339.0]: 'Parasuraman, Zeithaml and Berry [1] ได้ท าการศึกษาเรื่อง SERVQUAL มาตรวัด'
[[0mparagraph[0m] TEXT [108.0, 342.7, 376.8, 360.2]: 'แบบหลายรายการส าหรับวัดการรับรู้คุณภาพบริการของผู้บริโภค'
[[0mparagraph[0m] TEXT [108.0, 364.1, 522.8, 381.6]: 'ผลลัพธ์จากการเปรียบเทียบความคาดหวังของผู้ที่ได้รับบริการกับการรับรู้ต่อบริการที่'
[[0mparagraph[0m] TEXT [108.0, 385.3, 523.2, 402.8]: 'ได้รับโดย พบว่าสามารถจ าแนกคุณภาพในการบริการออกเป็น 5 มิติหลัก ได้แก่ กายภาพ ความ'
[[0mparagraph[0m] TEXT [108.0, 406.7, 522.9, 424.2]: 'น่าเชื่อถือ ความมั่นใจ การตอบสนองและความเข้าใจในลูกค้า ซึ่งมิติทั้งห้านี้สามารถอธิบายให้รับรู้'
[[0mparagraph[0m] TEXT [108.0, 428.0, 523.0, 445.4]: 'ได้ถึงคุณภาพในการบริการของผู้บริโภคได้อย่างมีนัยส าคัญ ผลการวิจัยยัง ผลการศึกษาสะท้อนให้'
[[0mparagraph[0m] TEXT [108.0, 449.2, 523.0, 466.7]: 'เห็นว่า ส่วนต่างระหว่างระดับความคาดหวังและการรับรู้จริง (Service Quality Gap) ถือเป็น'
[[0mparagraph[0m] TEXT [108.0, 470.6, 522.1, 488.0]: 'ประกอบส าคัญที่มีอิทธิพลต่อการก าหนดเกณฑ์มาตรฐานเชิงคุณภาพ ส่งผลต่อความพึงพอใจของผู้'
[[0mparagraph[0m] TEXT [108.0, 491.8, 522.5, 509.3]: 'ที่มาใช้ บริการ โดยแบบวัด SERVQUAL ที่พัฒนาขี้นมีความเที่ยงตรงและความเชื่อมั่นสูงสามารถ'
[[0mparagraph[0m] TEXT [108.0, 513.2, 526.9, 530.6]: 'น าไปประยุกต์ในการประเมินและปรับปรุงคุณภาพในด้านบริการในอุตสาหกรรมบริการ'
[[0mparagraph[0m] TEXT [108.0, 534.4, 198.6, 551.9]: 'หลากหลายประเภท'
[[0mparagraph[0m] TEXT [108.0, 555.8, 526.8, 573.2]: 'เครื่องมือมาตรฐานที่น ามาใช้ในระดับโลกในการวัดคุณภาพการบริการมีหลักที่ส าคัญ'
[[0mparagraph[0m] TEXT [108.0, 577.0, 523.6, 594.5]: 'คือ การหาค่าความแตกต่าง (Gap) ระหว่าง ความคาดหวังและการรับรู้จริง สูตรที่ใช้ในการค านวณ'
[[0mparagraph[0m] TEXT [108.0, 598.4, 161.3, 615.8]: 'เบื่องต้น คือ'
[[0mparagraph[0m] TEXT [299.5, 641.0, 524.3, 658.4]: 'Q = P – E                                             (2.1)'
[[0mparagraph[0m] TEXT [108.0, 662.2, 418.2, 679.7]: 'เมื่อ Q คือ คะแนนคุณภาพของบริการ'
[[0mparagraph[0m] TEXT [108.0, 683.6, 396.4, 701.0]: 'P คือ คะแนนระดับการรับรู้'
[[0mparagraph[0m] TEXT [108.0, 704.8, 420.5, 722.3]: 'E คือ คะแนนระดับความคาดหวัง'

================== PAGE 4 ==================
[[0mparagraph[0m] TEXT [108.0, 108.5, 492.5, 125.9]: 'ถ้าค่าของการรับรู้ (P) สูงกว่า ค่าความคาดหวัง (Q) คือ ลูกค้ามีความประทับใจมาก'
[[0mparagraph[0m] TEXT [108.0, 129.7, 488.5, 147.2]: 'ถ้าค่าของการรับรู้ (P) มีค่าเท่ากับ ค่าความคาดหวัง (Q) คือ ลูกค้ามีความพึงพอใจ'
[[0mparagraph[0m] TEXT [108.0, 151.1, 487.1, 168.5]: 'ถ้าค่าของการรับรู้ (P) ต ่ากว่า ค่าความคาดหวัง (Q) คือ ลูกค้ามีความไม่พอใจ'
[[96msub_section[0m] PREFIX [136.3, 172.3, 158.9, 189.8]: '[96m2.1.2[0m' | TEXT [164.7, 172.3, 523.1, 189.8]: 'ประวิทย์ ทองไชย เปรมฤดี ศิริคุปต์ และพัชรา สิริวัฒนเกตุ [2] ได้ท าการศึกษาเรื่อง'
[[0mparagraph[0m] TEXT [108.0, 193.7, 523.1, 211.1]: 'การศึกษาเปรียบเทียบคุณภาพการบริการด้วยระบบ SERVQUAL ของหน่วยจ่ายกลางโรงพยาบาล'
[[0mparagraph[0m] TEXT [108.0, 214.9, 197.1, 232.4]: 'เจริญกรุงประชารักษ์'
[[0mparagraph[0m] TEXT [108.0, 236.3, 522.1, 253.7]: 'จากการศึกษาพบว่าคุณภาพในการบริการของหน่วยจ่ายกลางโรงพยาบาลเจริญ'
[[0mparagraph[0m] TEXT [108.0, 257.5, 523.3, 275.0]: 'กรุงประชารักษ์ เมื่อประเมินด้วยระบบ SERVQUAL แสดงให้เห็นว่าผู้ที่มาใช้บริการได้มีระดับความ'
[[0mparagraph[0m] TEXT [108.0, 278.9, 526.3, 296.4]: 'คาดหวังต่อคุณภาพในการให้บริการอบู่ที่ระดับ “มากที่สุด” ขณะที่การรับรู้จริงต่อคุณภาพของ'
[[0mparagraph[0m] TEXT [108.0, 300.1, 523.3, 317.6]: 'บริการอยู่ในระดับ “มาก” ซึ่งผลต่างระหว่างการรับรู้และความคาดหวัง (service quality gap) มีค่า'
[[0mparagraph[0m] TEXT [108.0, 321.5, 522.5, 339.0]: 'เป็นลบโดยด้านที่มีช่องว่างติดลบมากที่สุดคือด้านการตอบสนองต่อผู้ใช้บริการรองลงมาคือด้านความ'
[[0mparagraph[0m] TEXT [108.0, 342.7, 523.1, 360.2]: 'น่าเชื่อถือไว้วางใจและด้านความเป็นรูปธรรมของการ บริการแต่การรับรู้คุณภาพ บริการต่างกัน'
[[0mparagraph[0m] TEXT [108.0, 364.1, 523.2, 381.6]: 'โดยมีนัยส าคัญทางด้านสถิติระหว่างเพศชายกับเพศหญิง ซึ่งบ่งชี้ว่าผู้ที่มาใช้ บริการได้รับรู้ถึง'
[[0mparagraph[0m] TEXT [108.0, 385.3, 523.1, 402.8]: 'คุณภาพของการบริการว่าต ่ากว่าความคาดหวังที่ตั้งไว้ในหลายมิติของ SERVQUAL โดยเฉพาะในมิติ'
[[0mparagraph[0m] TEXT [108.0, 406.7, 368.9, 424.2]: 'ของด้านการตอบสนองต่อผู้เรียนซึ่งมีคุณภาพต ่าที่สุดในหลายมิติ'
[[0mparagraph[0m] TEXT [108.0, 428.0, 526.1, 445.4]: 'กรอบแนวคิดต่างๆที่ได้จากการวิจัย ซึ่งประกอบด้วย 5 มิติ คือ ด้านกายภาพ'
[[0mparagraph[0m] TEXT [108.0, 449.2, 526.1, 466.7]: '(Tangibles) มีความสะอาดของเครื่องมือ และความทันสมัยของอุปกรณ์ที่ใช้ ด้านความน่าเชื่อถือ'
[[0mparagraph[0m] TEXT [108.0, 470.6, 521.9, 488.0]: '(Reliability) ความถูกต้องของการส่งมอบอุปกรณ์ต่างๆตามรายการที่ได้ก าหนดไว้ และชุด'
[[0mparagraph[0m] TEXT [108.0, 491.8, 523.0, 509.3]: 'เครื่องมือมีความครบถ้วน ด้านตอบสนอง (Responsiveness) มีความรวดเร็วในการแก้ไข'
[[0mparagraph[0m] TEXT [108.0, 513.2, 526.0, 530.6]: 'ปัญหาในการที่เครื่องมือที่ใช้ไม่เพียงพอ และมีความเต็มใจในการให้บริการ ด้านความเชื่อมั่น'
[[0mparagraph[0m] TEXT [108.0, 534.4, 526.3, 551.9]: '(Assurance) เจ้าหน้าที่มีความรู้ที่ท าให้ผู้ที่มารับบริการมีความมั่นใจในความสะอาดปราศจากเชื้อโรค'
[[0mparagraph[0m] TEXT [108.0, 555.8, 474.2, 573.2]: 'ด้านเอาใจใส่ (Empathy) มีความเข้าใจกันในแต่ละวอร์ด และมีการใช้การสื่อสารที่สุภาพ'
[[0mparagraph[0m] TEXT [108.0, 577.0, 522.1, 594.5]: 'สาเหตุเกิดมาจากพยาบาลที่ท างานอยู่หน้างานมีความคาดหวังต่อความรวดเร็วสูงมาก'
[[0mparagraph[0m] TEXT [108.0, 598.4, 214.6, 615.8]: 'เนื่องจากมีชีวิตของผู้ป่วย'
[[0mparagraph[0m] TEXT [108.0, 619.6, 522.9, 637.1]: 'แนวทางในการแก้ไขควรลดข้อจ ากัดในด้านทรัพยากรและระบบสารสนเทศที่ช่วยในการ'
[[0mparagraph[0m] TEXT [108.0, 641.0, 243.1, 658.4]: 'ติดตามสถานะต่างๆของอุปกรณ์'
[[96msub_section[0m] PREFIX [136.3, 662.2, 158.9, 679.7]: '[96m2.1.3[0m' | TEXT [164.7, 662.2, 522.6, 679.7]: 'นัตติยา ทองสร้อย [3] ได้ท าการศึกษาเรื่องความคาดหวังคุณภาพการบริการ'
[[0mparagraph[0m] TEXT [108.0, 683.6, 369.4, 701.0]: '(SERVQUAL) ที่ส่งผลต่อความตั้งใจใช้บริการร้านอาหารไทย'
[[0mparagraph[0m] TEXT [108.0, 704.8, 526.7, 722.3]: 'ผลจากการศึกษาพบว่า ความคาดหวังในด้านคุณภาพในการให้บริการ (SERVQUAL)'
[[0mparagraph[0m] TEXT [108.0, 726.2, 522.9, 743.6]: 'ส่งผลต่อความตั้งใจในด้านการบริการของร้านอาหาร มึมิติที่ส่งผลต่อความตั้งใจบริการ ได้แก่ ความ'
[[0mparagraph[0m] TEXT [108.0, 747.4, 523.3, 764.9]: 'น่าเชื่อถือ (Reliability) ด้านความตอบสนองความต้องการ (Responsiveness) และด้านเอาใจ'

================== PAGE 5 ==================
[[0mparagraph[0m] TEXT [108.0, 108.5, 523.1, 125.9]: 'ใส่ (Empathy) โดยที่ ด้านกายภาพ (Tangibles) และด้านความมั่นใจ (Assurance) ไม่พบสิ่งที่ส่งผล'
[[0mparagraph[0m] TEXT [108.0, 129.7, 522.8, 147.2]: 'กระทบต่อความตั้งใจในการใช้บริการอย่างมีนัยส าคัญ ทั้งนี้ ผลดังกล่าวสะท้อนต่อผู้บริโภคว่ามีการให้'
[[0mparagraph[0m] TEXT [108.0, 151.1, 522.9, 168.5]: 'ส าคัญต่อคุณภาพในการให้บริการเชิงพฤติกรรมและดูแลเอาใจใส่มากกว่าปัจจัยด้านกายภาพของร้าน'
[[0mparagraph[0m] TEXT [108.0, 172.3, 525.8, 189.8]: 'การปรับใช้มิติต่างๆในร้านอาหารไทย ประกอบด้วย 5 มิติ คือ ด้านกายภาพ'
[[0mparagraph[0m] TEXT [108.0, 193.7, 522.2, 211.1]: '(Tangibles) มีการตกแต่งร้านที่สะท้อนให้เห็นถึงวัฒนธรรมไทย โต๊ะอาหารและห้องน ้าค่อนข้าง'
[[0mparagraph[0m] TEXT [108.0, 214.9, 525.6, 232.4]: 'สะอาด และเมนูอาหารมีลักษณะที่อ่านง่ายและมีการใช้รูปภาพประกอบ ด้านความน่าเชื่อถือ'
[[0mparagraph[0m] TEXT [108.0, 236.3, 522.4, 253.7]: '(Reliability) อาหารที่ได้รับมีมาตรฐานเดียวกัน อาหารที่ได้น ามาเสิร์ฟถูกต้องตามที่สั่งไว้ และการ'
[[0mparagraph[0m] TEXT [108.0, 257.5, 523.1, 275.0]: 'คิดเงินมีความถูกต้องแม่นย า ด้านตอบสนอง (Responsiveness) มีความรวดเร็วในการ'
[[0mparagraph[0m] TEXT [108.0, 278.9, 526.7, 296.4]: 'เตรียมอาหารต่างๆ และพนักงานมีความกระตือรือร้นต่อการให้บริการ ด้านความเชื่อมั่น'
[[0mparagraph[0m] TEXT [108.0, 300.1, 523.2, 317.6]: '(Assurance) พนักงานมีความรู้ในเรื่องส่วนผสมต่างๆ และมีความสะอาดในการปรุงทุกขั้นตอน ด้าน'
[[0mparagraph[0m] TEXT [108.0, 321.5, 523.6, 339.0]: 'การเอาใจใส่ (Empathy) พนักงานมีการทักทายแบบไทย และมีการจดจ าความต้องการเมนูพิเศษ'
[[0mparagraph[0m] TEXT [108.0, 342.7, 151.8, 360.2]: 'ของลูกค้า'
[[0mparagraph[0m] TEXT [108.0, 364.1, 505.7, 381.6]: 'ตัวแปรที่ส าคัญของการท าการวิจัย ได้แก่ การกลับมาใช้ซ ้าของลูกค้า ลูกค้าบอกต่อ'
[[0mparagraph[0m] TEXT [108.0, 385.3, 290.5, 402.8]: 'และเต็มใจจ่ายต่อให้ราคาอาหารมีราคาที่สูง'
[[96msub_section[0m] PREFIX [136.3, 406.7, 158.9, 424.2]: '[96m2.1.4[0m' | TEXT [164.7, 406.7, 523.4, 424.2]: 'คณพัฒน์ กรีนิกร และณัฐพล อัสสะรัตน์ [4] ได้ท าการศึกษาเรื่องอิทธิพลของ'
[[0mparagraph[0m] TEXT [108.0, 428.0, 523.0, 445.4]: 'คุณภาพการบริหารการที่มีต่อบุคลิกภาพแบรนด์ในกรณีผู้บริโภคระดับการปฏิสัมพันธ์กับธุรกิจบริการ'
[[0mparagraph[0m] TEXT [108.0, 449.2, 165.5, 466.7]: 'ที่แตกต่างกัน'
[[0mparagraph[0m] TEXT [108.0, 470.6, 521.8, 488.0]: 'จากการศึกษาพบว่าคุณภาพในการบริการ มีอิทธิพลในเชิงบวกอย่างมีนัยส าคัญ'
[[0mparagraph[0m] TEXT [108.0, 491.8, 522.6, 509.3]: 'ต่อบุคลิกภาพแบรน มีอยู่ 2 มิติหลัก คือ ด้านความเชี่ยวชาญ ประสิทธิภาพในการบริการมี'
[[0mparagraph[0m] TEXT [108.0, 513.2, 523.0, 530.6]: 'ความแม่นย าและมีความเป็นมืออาชีพ ท าให้ผู้บริโภคมองว่าแบรนด์มีความรู้ และความสามารถที่'
[[0mparagraph[0m] TEXT [108.0, 534.4, 522.6, 551.9]: 'พึ่งพาได้ ด้านความจริงใจบริการมีความโปร่งใส สามารถตรวจสอบได้ ท าให้แบรนด์มีบุคลิกภาพที่'
[[0mparagraph[0m] TEXT [108.0, 555.8, 380.0, 573.2]: 'ดูแล้วแสดงออกถึงความจริงใจและคุณธรรมในการส่งมอบบริการ'
[[0mparagraph[0m] TEXT [108.0, 577.0, 523.2, 594.5]: 'การน ามิติต่างๆมาใช้ มีด้านความน่าเชื่อถือ (Reliability) มีการส่งมอบที่ตรงเวลา ข้อมูล'
[[0mparagraph[0m] TEXT [108.0, 598.4, 523.1, 615.8]: 'มีความแม่นย า และท าตามที่สัญญาไว้กับคู่ค้า ด้านความเชื่อมั่น (Assurance) พนักงานมีความรู้ทาง'
[[0mparagraph[0m] TEXT [108.0, 619.6, 523.3, 637.1]: 'กฎระเบียบ และสามารตอบค าถามเชิงลึกได้ ด้านทางกายภาพ (Tangibles) มีการน าระบบ IT มา'
[[0mparagraph[0m] TEXT [108.0, 641.0, 305.3, 658.4]: 'ประยุกต์ใช้เพื่อยกระดับมาตรฐานการให้บริการ'
[[96msub_section[0m] PREFIX [136.3, 662.2, 158.9, 679.7]: '[96m2.1.5[0m' | TEXT [164.7, 662.2, 522.3, 679.7]: 'ฉัตร โชติช่วง [5] ได้ท าการศึกษาเรื่องคุณภาพงานบริการที่มีอิทธิพลต่อความพึงพอใจ'
[[0mparagraph[0m] TEXT [108.0, 683.6, 220.0, 701.0]: 'ของผู้ใช้บริการศูนย์บริการ'
[[0mparagraph[0m] TEXT [108.0, 704.8, 522.9, 722.3]: 'จากการศึกษาพบว่า ปัจจัยด้านคุณภาพการบริการรวมกัน ท าให้ความพึงพอใจของผู้'
[[0mparagraph[0m] TEXT [108.0, 726.2, 522.8, 743.6]: 'ที่มาใช้บริการที่ศูนย์ทรูมูฟอย่างมีนัยส าคัญ โดยอธิบายความ แปรปรวนของความพึงพอใจในการ'

================== PAGE 6 ==================
[[0mparagraph[0m] TEXT [108.0, 108.5, 522.7, 125.9]: 'บริการได้ ร้อยละ 43.4 ของตัวแปรทั้งหมด ปัจจัยคุณภาพ ด้านการเอาใจใส่ในการบริการจะมี'
[[0mparagraph[0m] TEXT [108.0, 129.7, 491.3, 147.2]: 'อิทธิพลมากสุด รองลงมา คือ ความเชื่อมั่น ความเชื่อถือการตอบสนอง และลักษณะภายนอก'
[[0mparagraph[0m] TEXT [108.0, 151.1, 523.1, 168.5]: 'การน ามิติต่างๆมาใช้ มีด้านทางกายภาพ (Tangibles) อุปกรณ์ที่น ามาทดลองใช้มีความ'
[[0mparagraph[0m] TEXT [108.0, 172.3, 523.2, 189.8]: 'ทันสมัย มีการน าระบบคิวอัตโนมัติที่ใช้งานง่ายมาใช้ และมีการจัดวางสินค้าใน Shop ด้านความ'
[[0mparagraph[0m] TEXT [108.0, 193.7, 522.2, 211.1]: 'น่าเชื่อถือ (Reliability) การคิดบริการมีความถูกต้องแม่นย า และการเปลี่ยนแพ็กเกจหรือการแก้ไข'
[[0mparagraph[0m] TEXT [108.0, 214.9, 523.2, 232.4]: 'สัญญาณได้ผลตามที่ตกลงกันไว้ ด้านการตอบสนอง (Responsiveness) พนักงานมีความกระตือรือร้น'
[[0mparagraph[0m] TEXT [108.0, 236.3, 523.1, 253.7]: 'ในการรับเรื่อง ด้านความเชื่อมั่น (Assurance) พนักงานมีความรู้เกี่ยวกับโปรโมชั่น และสามารถตั้งค่า'
[[0mparagraph[0m] TEXT [108.0, 257.5, 522.5, 275.0]: 'สมาร์ทโฟนรุ่นใหม่ๆ ด้านเอาใจใส่ (Empathy) สามารถแนะน าโปรโมชั่นที่คุ้มค่าที่สุดได้ และมีการ'
[[0mparagraph[0m] TEXT [108.0, 278.9, 226.3, 296.4]: 'สื่อสารที่สุภาพ รับฟังปัญหา'
[[94msection[0m] PREFIX [108.0, 321.5, 122.8, 339.0]: '[94m2.2[0m' | TEXT [136.3, 321.5, 220.3, 339.0]: 'สถิติที่ใช้ในงานวิจัย'
[[96msub_section[0m] PREFIX [136.3, 342.7, 158.9, 360.2]: '[96m2.2.1[0m' | TEXT [164.7, 342.7, 210.9, 360.2]: 'G*POWER'
[[0mparagraph[0m] TEXT [108.0, 364.1, 526.8, 381.6]: 'G*Power เป็นโปรแกรมที่ใช้วิเคราะห์และทดสอบทางสถิติ (Statistical Power'
[[0mparagraph[0m] TEXT [108.0, 385.3, 472.4, 402.8]: 'Analysis) โดยมีวัตถุประสงค์หลักเพื่อค านวณหาขนาดของกลุ่มตัวอย่าง (Sample Size)'
[[0mparagraph[0m] TEXT [108.0, 406.7, 523.2, 424.2]: 'โปรแกรมนี้ถูกพัฒนาโดย Faul Erdfelder LangและBuchnerและได้รับ การยอมรับใน'
[[0mparagraph[0m] TEXT [108.0, 428.0, 200.4, 445.4]: 'แวดวงวิชาการทั่วโลก'
[[0mimage_caption[0m] PREFIX [241.2, 639.3, 282.7, 656.8]: '[0mรูปที่  2.1[0m' | TEXT [289.6, 639.3, 389.8, 656.8]: 'โปรแกรม G*power [6]'
